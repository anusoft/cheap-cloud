# ─────────────────────────────────────────────────────────────────────────────
# cheap-cloud environment. Copy to `.env` and fill in. Missing provider keys
# simply skip that provider during `bun fetch` (the run does not fail).
# ─────────────────────────────────────────────────────────────────────────────

# AWS  — Price List Bulk API is PUBLIC. No key required.
# Azure — Retail Prices API is PUBLIC. No key required.

# Google Cloud — Cloud Billing Catalog API (needs an API key with the
# "Cloud Billing API" enabled).
GCP_API_KEY=

# Alibaba Cloud — ECS RPC API (AccessKey pair).
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=

# Tencent Cloud — CVM API (SecretId / SecretKey).
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Huawei Cloud — IAM AK/SK pair + your domain (account) id for BSS pricing.
HUAWEI_ACCESS_KEY=
HUAWEI_SECRET_KEY=
HUAWEI_DOMAIN_ID=

# Hetzner Cloud — a project-scoped API token (Read permission is enough).
# Console → Project → Security → API Tokens → Generate. Bangkok uses the
# Singapore (sin) location as a proxy. Prices are EUR; converted to USD live
# (override the FX rate with HETZNER_EUR_USD if you want a fixed rate).
HETZNER_API_TOKEN=
# HETZNER_EUR_USD=1.08

# ─────────────────────────────────────────────────────────────────────────────
# LLM "Ask the data" panel — any OpenAI-compatible endpoint. The web app calls
# it directly from the browser, so these MUST be VITE_-prefixed (Vite only
# exposes VITE_* to client code). They are baked in at build time: set them for
# local `bun dev` to enable chat. The static GitHub Pages build leaves them
# unset, so the chat panel hides itself there.
#   • OpenAI:     https://api.openai.com/v1
#   • Ollama:     http://localhost:11434/v1   (key can be any non-empty value)
#   • LM Studio:  http://localhost:1234/v1
# ─────────────────────────────────────────────────────────────────────────────
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
